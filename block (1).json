!function(){if(!("IntersectionObserver"in window))return;const e=document.querySelectorAll(".wing-services-list__card");if(!e.length)return;const s=new IntersectionObserver(e=>{e.forEach(e=>{e.isIntersecting&&(e.target.classList.add("is-visible"),s.unobserve(e.target))})},{threshold:.1});e.forEach((e,t)=>{e.style.setProperty("--wing-delay",60*t+"ms"),e.classList.add("wing-anim"),s.observe(e)})}();