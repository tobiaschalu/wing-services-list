.wing-services-list{--wing-accent:#2563eb;--wing-accent-light:color-mix(in srgb,var(--wing-accent) 10%,#fff);--wing-text:#111827;--wing-muted:#6b7280;--wing-surface:#fff;--wing-border:#e5e7eb;--wing-radius:12px;--wing-radius-sm:8px;--wing-shadow:0 1px 3px rgba(0,0,0,.08),0 4px 16px rgba(0,0,0,.07);--wing-shadow-hover:0 4px 8px rgba(0,0,0,.1),0 12px 32px rgba(0,0,0,.12);--wing-transition:all .22s cubic-bezier(.4,0,.2,1);box-sizing:border-box}.wing-services-list *,.wing-services-list :after,.wing-services-list :before{box-sizing:inherit}.wing-services-list__header{margin-bottom:2.5rem;text-align:center}.wing-services-list__heading{color:var(--wing-text);font-size:clamp(1.5rem,3vw,2.25rem);font-weight:700;line-height:1.2;margin:0 0 .5rem}.wing-services-list__subheading{color:var(--wing-muted);font-size:1.0625rem;line-height:1.6;margin:0}.wing-services-list__grid{display:grid;gap:1.5rem;grid-template-columns:1fr}@media(min-width:640px){.wing-services-list__grid--2,.wing-services-list__grid--3,.wing-services-list__grid--4{grid-template-columns:repeat(2,1fr)}}@media(min-width:1024px){.wing-services-list__grid--3{grid-template-columns:repeat(3,1fr)}.wing-services-list__grid--4{grid-template-columns:repeat(4,1fr)}}.wing-services-list__card{background:var(--wing-surface);border-radius:var(--wing-radius);display:flex;flex-direction:column;overflow:hidden;position:relative;transition:var(--wing-transition)}.wing-services-list__card--shadow{box-shadow:var(--wing-shadow)}.wing-services-list__card--shadow:hover{box-shadow:var(--wing-shadow-hover);transform:translateY(-3px)}.wing-services-list__card--border{border:1.5px solid var(--wing-border)}.wing-services-list__card--border:hover{border-color:var(--wing-accent)}.wing-services-list__card--flat{background:var(--wing-accent-light)}.wing-services-list__card-image{aspect-ratio:16/9;background:var(--wing-border);overflow:hidden}.wing-services-list__card-image img{display:block;height:100%;-o-object-fit:cover;object-fit:cover;transition:transform .4s cubic-bezier(.4,0,.2,1);width:100%}.wing-services-list__card:hover .wing-services-list__card-image img{transform:scale(1.04)}.wing-services-list__card-content{display:flex;flex:1;flex-direction:column;padding:1.25rem 1.375rem 1.5rem}.wing-services-list__card-title{color:var(--wing-text);font-size:1.0625rem;font-weight:700;line-height:1.3;margin:0 0 .5rem}.wing-services-list__card-desc{color:var(--wing-muted);flex:1;font-size:.9375rem;line-height:1.6;margin:0}.wing-services-list__card-link{align-items:center;color:var(--wing-accent);display:inline-flex;font-size:.9rem;font-weight:600;gap:.35em;margin-top:1.125rem;text-decoration:none;transition:gap .2s ease}.wing-services-list__card-link:hover{gap:.55em;text-decoration:underline}.wing-services-list__card-link svg{flex-shrink:0;height:1em;width:1em}.wing-services-list__card--border:before{background:var(--wing-accent);border-radius:var(--wing-radius) var(--wing-radius) 0 0;content:"";height:3px;right:0;position:absolute;left:0;top:0;transform:scaleX(0);transform-origin:right;transition:transform .25s ease}.wing-services-list__card--border:hover:before{transform:scaleX(1)}.alignwide .wing-services-list__grid,.wp-block-wing-services-list.alignwide .wing-services-list__grid{max-width:100%}@media(prefers-reduced-motion:no-preference){.wing-services-list__card.wing-anim{opacity:0;transform:translateY(20px)}.wing-services-list__card.wing-anim.is-visible{animation:wingFadeUp .5s cubic-bezier(.4,0,.2,1) var(--wing-delay,0ms) forwards}@keyframes wingFadeUp{to{opacity:1;transform:translateY(0)}}}.wing-services-list__grid{list-style:none;margin:0;padding:0}.wing-services-list__card-link:focus-visible{border-radius:3px;outline:3px solid var(--wing-accent);outline-offset:3px;text-decoration:none}@media(forced-colors:active){.wing-services-list__card{border:1px solid ButtonText}.wing-services-list__card-link{color:LinkText}.wing-services-list__card--border:before{background:Highlight}}
